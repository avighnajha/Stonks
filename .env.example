# Example environment variables for local development
# Copy this to .env and fill values (do NOT commit your .env)

# JWT secret used to sign/verify tokens (use a strong secret in production)
JWT_SECRET=change_me_jwt_secret

# Internal API key used for inter-service requests (keep secret)
INTERNAL_API_KEY=change_me_internal_api_key

# Optional overrides for service base URLs (leave blank to use Docker hostnames)
WALLET_SERVICE_URL=
PORTFOLIO_SERVICE_URL=
MARKETPLACE_SERVICE_URL=
TRADING_SERVICE_URL=

# Frontend API base (gateway)
VITE_API_URL=http://localhost:8080

# Database (Postgres) connection (used by services)
DATABASE_URL=postgresql://user:password@postgres_db:5432/stonks_main_db
